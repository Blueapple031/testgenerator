# ===== LLM =====
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=sk-ant-...

# ===== Embedding =====
EMBEDDING_PROVIDER=openai
# EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=intfloat/multilingual-e5-large
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ===== PostgreSQL =====
DATABASE_URL=postgresql+asyncpg://dontdelay:changeme@postgres:5432/dontdelay
POSTGRES_PASSWORD=changeme

# ===== MinIO =====
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=dontdelay-exam

# ===== OCR / Vision =====
OCR_ENABLED=true
UPSTAGE_API_KEY=
VISION_ENABLED=true
# EXTRACTION_PIPELINE=vision_first  # vision_first | ocr_first (A/B 비교)
# VISION_MIN_DRAWINGS=10

# ===== App =====
SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000
DEBUG=false

# ===== Pilot auth (파일럿 배포) =====
PILOT_AUTH_ENABLED=true
PILOT_ADMIN_KEY=your-admin-secret-key
PILOT_ACCOUNTS_SYNC_ON_STARTUP=true
# backend 기동 시 alembic upgrade + pilot_accounts.yaml 동기화가 자동 실행됩니다.

# ===== Limits =====
EXAM_MAX_UPLOAD_BYTES=52428800
EXAM_CHUNK_SIZE=800
EXAM_CHUNK_OVERLAP=120
